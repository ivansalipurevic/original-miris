## Email (SMTP) configuration for /api/order
#
# This app sends 2 emails on every order:
# - to the customer (order confirmation)
# - to you/admin (order details so you know what to pack)
#
# Use a real SMTP provider in production (recommended: your domain email / SendGrid / Mailgun / Postmark).
# For local testing you can also use Mailtrap or Ethereal (see notes below).

# Address shown as sender
MAIL_FROM="Original Miris <no-reply@your-domain.com>"

# Where you receive admin notifications
ADMIN_EMAIL_TO="you@your-domain.com"

# SMTP settings (preferred)
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"
# Set true for port 465 (SSL). For 587 usually leave false/empty.
SMTP_SECURE="false"

# --- Dev option (Mailtrap inbox) ---
# If you want to keep using Mailtrap, you can set these instead of SMTP_*
# MAILTRAP_HOST="sandbox.smtp.mailtrap.io"
# MAILTRAP_PORT="587"
# MAILTRAP_USER="..."
# MAILTRAP_PASS="..."

